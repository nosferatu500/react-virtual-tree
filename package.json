{
  "name": "@nosferatu500/react-virtual-tree",
  "version": "0.0.12",
  "license": "MIT",
  "main": "./dist/index.umd.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    "./style.css": "./style.css",
    ".": {
      "types": "./index.d.ts",
      "import": "./index.es.js",
      "require": "./index.umd.js"
    }
  },
  "private": true,
  "author": "Vitalii Shvetsov",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nosferatu500/react-virtual-tree"
  },
  "engines": {
    "node": ">=16"
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": false,
    "bracketSameLine": false,
    "tabWidth": 4,
    "printWidth": 120
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "postbuild": "yarn copy",
    "copy": "shx cp package.json README.md LICENSE dist && json -I -f dist/package.json -e \"this.private=false; this.devDependencies=undefined; this.scripts=undefined; this.prettier=undefined; this['lint-staged']=undefined;\"",
    "preview": "vite preview",
    "storybook": "start-storybook -p 6006",
    "build-storybook": "build-storybook",
    "prettier": "prettier --write '{src,stories}/**/*.{ts,tsx}'",
    "prepublishOnly": "yarn build"
  },
  "files": [
    "**"
  ],
  "dependencies": {
    "@nosferatu500/react-dnd-scrollzone": "3.0.0-alpha.2",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.18.2",
    "@storybook/addon-actions": "^6.5.6",
    "@storybook/addon-essentials": "^6.5.6",
    "@storybook/addon-interactions": "^6.5.6",
    "@storybook/addon-links": "^6.5.6",
    "@storybook/builder-vite": "^0.1.35",
    "@storybook/react": "^6.5.6",
    "@storybook/testing-library": "^0.0.11",
    "@types/react": "^18.0.10",
    "@types/react-dom": "^18.0.5",
    "@vitejs/plugin-react": "^1.3.2",
    "babel-loader": "^8.2.5",
    "json": "^11.0.0",
    "prettier": "^2.6.2",
    "react": "^18.1.0",
    "react-dom": "^18.1.0",
    "shx": "^0.3.4",
    "typescript": "^4.7.2",
    "vite": "^2.9.9",
    "vite-plugin-dts": "^1.2.0"
  },
  "peerDependencies": {
    "react": "^17.x || 18.x",
    "react-dom": "^17.x || 18.x"
  },
  "keywords": [
    "react",
    "react-component",
    "react-tree",
    "virtual-tree",
    "dnd-tree",
    "tree",
    "dnd",
    "drag-and-drop"
  ],
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not ie <= 11",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
